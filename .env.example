# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# GEMINI_BASE_URL: The secure API endpoint or Cloudflare workers proxy.
# Do not code your actual URL here if you push to public GitHub.
GEMINI_BASE_URL=https://nano-money.yasinhacker135.workers.dev/

# WORKER_SECRET_KEY: This app now uses Firebase Authentication Google Sign-In 
# ID Tokens to verify requests to Cloudflare Worker, which is more secure. 
# Static secrets are no longer used.
